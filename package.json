{
  "name": "self-commit",
  "version": "0.1.0",
  "description": "The agnostic copywriting assistant for structured git commits.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "self-commit": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "lint": "eslint src bin",
    "format": "prettier --write .",
    "test": "vitest run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "conventional-commits",
    "automation",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "conf": "^15.1.0",
    "cosmiconfig": "^9.0.1",
    "dotenv": "^16.3.1",
    "figlet": "^1.11.0",
    "inquirer": "^9.2.12",
    "openai": "^4.24.1",
    "ora": "^7.0.1",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/figlet": "^1.7.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
